{
  "expo": {
    "name": "漫记",
    "slug": "manji-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/163.png",
    "scheme": "manjimobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/images/163.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.mouman.manjimobile",
      // 新增：网络权限（解决APK无法访问接口的核心）
      "permissions": [
        "INTERNET",
        "ACCESS_NETWORK_STATE"
      ],
      // 新增：允许HTTP明文请求（解决非HTTPS接口被拦截问题）
      "usesCleartextTraffic": true
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/163.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/163.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e3bd6268-87ae-43d2-9bc9-a6486b40093a"
      }
    }
  }
}